#!/usr/bin/env bash
# BigLinux Microphone Noise Reduction - Entry Point
# Launches the GTK4/Libadwaita application for microphone noise reduction

export GTK_USE_PORTAL=1

# Detect development environment:
# If this script lives inside a repo with src/biglinux_microphone/, use that.
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_repo_root="${_script_dir}/../.."
if [[ -f "${_repo_root}/pyproject.toml" && -d "${_repo_root}/src/biglinux_microphone" ]]; then
    cd "${_repo_root}/src/biglinux_microphone"
    exec python3 __init__.py "$@"
fi

# Production: search for installed module in system site-packages
for i in /usr/lib/python3.{25..6}/site-packages/biglinux_microphone; do
    if [[ -d "$i" ]]; then
        cd "$i"
        break
    fi
done

exec python3 __init__.py "$@"
