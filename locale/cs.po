msgstr "Extra jasnost"
# 
# File: biglinux-noise-reduction-pipewire/src/biglinux_microphone/config.py, line: 588
msgid "Enhance treble and details."
msgstr "Zvyšte výšky a detaily."
# 
# File: biglinux-noise-reduction-pipewire/src/biglinux_microphone/config.py, line: 592
