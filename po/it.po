#: src/ui/views/mic.rs:232 src/ui/views/output.rs:161
msgid "High-pass filter"
msgstr "Filtro passa-alto"

#: src/ui/views/mic.rs:233
msgid "Cuts low-frequency rumble — AC, wind, mic-stand bumps."
msgstr ""
"Taglia il rimbombo a bassa frequenza — corrente alternata, vento, urti al "
"supporto del microfono."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 308
#: src/ui/views/mic.rs:251 src/ui/views/output.rs:180
msgid "Silence gate"
msgstr "Cancello silenzio"

#: src/ui/views/mic.rs:253
msgid ""
"Mutes the mic during pauses so listeners hear silence instead of hiss. "
"Higher = more aggressive."
msgstr ""
"Mette in muto il microfono durante le pause così gli ascoltatori sentono il "
"silenzio invece del fruscio. Più alto = più aggressivo."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 477
#: src/ui/views/mic.rs:273 src/ui/views/output.rs:57
msgid "Equalizer"
msgstr "Equalizzatore"

#: src/ui/views/mic.rs:275
msgid ""
"10-band parametric EQ. Pick a preset or drag each band between -40 dB and "
"+40 dB."
msgstr ""
"EQ parametrico a 10 bande. Scegli un preset o trascina ogni banda tra -40 dB"
" e +40 dB."

#: src/ui/views/mic.rs:319
msgid ""
"Shifts the pitch of your voice without retiming. Left = deeper, right = "
"higher. Center keeps your natural voice."
msgstr ""
"Modifica l’intonazione della tua voce senza cambiare la velocità. Sinistra ="
" più profonda, destra = più acuta. Al centro mantiene la voce naturale."

