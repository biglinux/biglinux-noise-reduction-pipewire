#: src/ui/views/mic.rs:206
msgid ""
"Restores high-frequency clarity (sibilants like \"s\", \"sh\") after "
"suppression. Lower only if your voice already sounds harsh."
msgstr ""
"Ripristina la chiarezza delle alte frequenze (sibilanti come \"s\", \"sh\") "
"dopo la soppressione. Abbassa solo se la tua voce suona già aspra."

# File: biglinux-noise-reduction-
