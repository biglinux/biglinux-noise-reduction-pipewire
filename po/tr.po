# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 438
#: src/ui/views/mic.rs:56 src/ui/views/mic.rs:367
msgid "Voice changer"
msgstr "Ses değiştirici"

#: src/ui/views/mic.rs:106
msgid ""
"Removes the speaker's echo from your microphone — useful on calls without "
"headphones."
msgstr ""
"Mikrofonunuzdaki hoparlör yankısını kaldırır — kulaklıksız görüşmelerde "
"faydalıdır."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 687
#: src/ui/views/mic.rs:118
msgid "Echo cancellation"
msgstr "Yankı iptali"

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 709
#: src/ui/views/mic.rs:158
msgid "AI noise filter"
msgstr "Yapay zeka gürültü filtresi"

#: src/ui/views/mic.rs:167
msgid ""
"GTCRN neural filter on your microphone. Off bypasses every fine-tune control"
" below."
msgstr ""
"Mikrofonunuzda GTCRN sinirsel filtresi. Kapalı konumda aşağıdaki tüm ince "
"ayar kontrolleri devre dışı kalır."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 326
#: src/ui/views/mic.rs:184 src/ui/views/output.rs:101
msgid "Neural model"
msgstr "Sinir ağı modeli"

#: src/ui/views/mic.rs:186
msgid ""
"DNS3 removes more noise but can smudge consonants. VCTK is gentler and "
"lighter on CPU — good for podcasts."
msgstr ""
"DNS3 daha fazla gürültüyü kaldırır ancak ünsüzleri bulanıklaştırabilir. VCTK"
" daha nazik ve CPU üzerinde hafiftir — podcastler için uygundur."

#: src/ui/views/mic.rs:193 src/ui/views/output.rs:110
msgid "GTCRN – DNS3 (strong)"
msgstr "GTCRN – DNS3 (güçlü)"

#: src/ui/views/mic.rs:194 src/ui/views/output.rs:111
msgid "GTCRN – VCTK (gentle)"
msgstr "GTCRN – VCTK (nazik)"

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 323
#: src/ui/views/mic.rs:211 src/ui/views/output.rs:128
msgid "Model"
msgstr "Model"

#: src/ui/views/mic.rs:218 src/ui/views/output.rs:135
msgid "Noise strength (no voice)"
msgstr "Gürültü gücü (ses yok)"

#: src/ui/views/mic.rs:220
msgid ""
"How hard the filter works in the gaps between words. 100% mutes anything "
"that isn't voice."
msgstr ""
"Kelimeler arasındaki boşluklarda filtrenin ne kadar güçlü çalıştığı. %100, "
"ses olmayan her şeyi sessize alır."

#: src/ui/views/mic.rs:226 src/ui/views/mic.rs:244 src/ui/views/output.rs:143
#: src/ui/views/output.rs:165
msgid "Strength"
msgstr "Güç"

#: src/ui/views/mic.rs:236 src/ui/views/output.rs:153
msgid "Voice strength (while speaking)"
msgstr "Konuşma sırasında ses gücü"

#: src/ui/views/mic.rs:238
msgid ""
"How hard the filter works while you talk. Lower if your voice sounds "
"robotic; raise if noise still bleeds through."
msgstr ""
"Konuşurken filtrenin ne kadar yoğun çalıştığı. Sesiniz robotik geliyorsa "
"düşürün; gürültü hala geçiyorsa artırın."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 392
#: src/ui/views/mic.rs:254 src/ui/views/output.rs:175
msgid "Voice presence"
msgstr "Ses varlığı"

#: src/ui/views/mic.rs:256
msgid ""
"Restores high-frequency clarity (sibilants like \"s\", \"sh\") after "
"suppression. Lower only if your voice already sounds harsh."
msgstr ""
"Bastırmadan sonra yüksek frekans netliğini (s, ş gibi sibilantlar) geri "
"kazandırır. Sesiniz zaten sertse sadece düşürün."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 392
#: src/ui/views/mic.rs:262 src/ui/views/output.rs:187
msgid "Recovery"
msgstr "Kurtarma"

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 477
#: src/ui/views/mic.rs:282 src/ui/views/output.rs:207
msgid "High-pass filter"
msgstr "Yüksek geçiren filtre"

#: src/ui/views/mic.rs:283
msgid "Cuts low-frequency rumble — AC, wind, mic-stand bumps."
msgstr ""
"Düşük frekanslı uğultuyu keser — AC, rüzgar, mikrofon standı darbeleri."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 308
#: src/ui/views/mic.rs:301 src/ui/views/output.rs:226
msgid "Silence gate"
msgstr "Sessizlik kapısı"

#: src/ui/views/mic.rs:303
msgid ""
"Mutes the mic during pauses so listeners hear silence instead of hiss. "
"Higher = more aggressive."
msgstr ""
"Duraklamalarda mikrofonu sessize alır, böylece dinleyiciler tıslama yerine "
"sessizlik duyar. Yüksek değer = daha agresif."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 434
# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 472
#: src/ui/views/mic.rs:311 src/ui/views/mic.rs:457 src/ui/views/output.rs:233
#: src/ui/views/output.rs:263 src/ui/views/simple.rs:69
#: src/ui/views/simple.rs:177
msgid "Intensity"
msgstr "Yoğunluk"

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 477
#: src/ui/views/mic.rs:323 src/ui/views/output.rs:56
msgid "Equalizer"
msgstr "Ekolayzır"

#: src/ui/views/mic.rs:325
msgid ""
"10-band parametric EQ. Pick a preset or drag each band between -40 dB and "
"+40 dB."
msgstr ""
"10 bantlı parametrik EQ. Bir ön ayar seçin veya her bandı -40 dB ile +40 dB "
"arasında sürükleyin."

#: src/ui/views/mic.rs:369
msgid ""
"Shifts the pitch of your voice without retiming. Left = deeper, right = "
"higher. Center keeps your natural voice."
msgstr ""
"Sesinizin perdesini zamanlamayı değiştirmeden kaydırır. Sol = daha derin, "
"sağ = daha yüksek. Ortada doğal sesiniz kalır."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 1147
#: src/ui/views/mic.rs:389
msgid "Deep"
msgstr "Derin"

#: src/ui/views/mic.rs:390
msgid "Lower"
msgstr "Düşük"

#: src/ui/views/mic.rs:391
msgid "Natural"
msgstr "Doğal"

#: src/ui/views/mic.rs:392
msgid "Higher"
msgstr "Yüksek"

#: src/ui/views/mic.rs:393
msgid "Chipmunk"
msgstr "Sincap sesi"

#: src/ui/views/mic.rs:404
msgid "Pitch"
msgstr "Perde"

#: src/ui/views/mic.rs:416 src/ui/views/simple.rs:144
msgid "Headphones only — speakers cause feedback."
msgstr "Sadece kulaklık — hoparlörler geri bildirime neden olur."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 550
#: src/ui/views/mic.rs:426 src/ui/views/simple.rs:154
msgid "Hear my voice"
msgstr "Sesimi duy"

#: src/ui/views/mic.rs:434
msgid "Delay (ms)"
msgstr "Gecikme (ms)"

#: src/ui/views/mic.rs:452 src/ui/views/output.rs:255
msgid "Compressor"
msgstr "Kompresör"

#: src/ui/views/mic.rs:453
msgid ""
"Evens out loud peaks and quiet parts so your voice stays at a steady volume."
msgstr ""
"Sesinizin sabit bir ses seviyesinde kalması için yüksek ve düşük sesleri "
"dengeler."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 310
#: src/ui/views/output.rs:37
msgid "AI noise reduction"
msgstr "Yapay zeka gürültü azaltma"

#: src/ui/views/output.rs:43
msgid "Audio enhancements"
msgstr "Ses geliştirmeleri"

#: src/ui/views/output.rs:58
msgid ""
"10-band parametric EQ on what you hear. Pick a preset or drag each band "
"between -40 dB and +40 dB."
msgstr ""
"Duyduklarınız üzerinde 10 bantlı parametrik EQ. Bir ön ayar seçin veya her "
"bandı -40 dB ile +40 dB arasında sürükleyin."

#: src/ui/views/output.rs:89
msgid "Enable output filter"
msgstr "Çıkış filtresini etkinleştir"

#: src/ui/views/output.rs:91
msgid ""
"Filters audio reaching your speakers in real time. Stays attached after "
"toggling, so playback and calls keep running."
msgstr ""
"Hoparlörlerinize ulaşan sesi gerçek zamanlı filtreler. Açma/kapama sonrası "
"bağlı kalır, böylece oynatma ve aramalar devam eder."

#: src/ui/views/output.rs:103
msgid ""
"DNS3 strips more noise (good for harsh streams); VCTK is gentler (good for "
"music or clean voice)."
msgstr ""
"DNS3 daha fazla gürültü giderir (sert yayınlar için iyi); VCTK daha naziktir"
" (müzik veya temiz ses için uygun)."

#: src/ui/views/output.rs:137
msgid ""
"How hard the filter works during silent moments in playback. Higher = "
"quieter background between sentences."
msgstr ""
"Oynatma sırasında sessiz anlarda filtrenin ne kadar çalıştığı. Yüksek = "
"cümleler arasındaki arka plan daha sessiz."

#: src/ui/views/output.rs:155
msgid ""
"How hard the filter works while voices play. Lower if they sound robotic; "
"raise if noise still bleeds through."
msgstr ""
"Sesler çalarken filtrenin ne kadar çalıştığı. Sesler robotik geliyorsa "
"düşürün; gürültü hala geçiyorsa artırın."

#: src/ui/views/output.rs:177
msgid ""
"Restores high-frequency clarity after suppression. Lower only if the source "
"already sounds harsh."
msgstr ""
"Bastırmadan sonra yüksek frekans netliğini geri kazandırır. Kaynak zaten "
"sert geliyorsa sadece düşürün."

#: src/ui/views/output.rs:208
msgid "Cuts low-frequency rumble from playback — wind, AC noise."
msgstr "Oynatmadaki düşük frekanslı uğultuyu keser — rüzgar, klima gürültüsü."

#: src/ui/views/output.rs:227
msgid ""
"Mutes playback during silent moments so you don't hear hiss between words."
msgstr ""
"Sessiz anlarda oynatmayı sessize alır, böylece kelimeler arasındaki "
"tıslamayı duymazsınız."

#: src/ui/views/output.rs:257
msgid ""
"Evens out volume across loud and quiet speakers — useful for meetings with "
"mixed mic levels."
msgstr ""
"Yüksek ve düşük sesli hoparlörler arasında ses seviyesini dengeler — karışık"
" mikrofon seviyeleri olan toplantılar için faydalı."

#: src/ui/views/simple.rs:115
msgid "Noise filter"
msgstr "Gürültü filtresi"

#: src/ui/views/simple.rs:124
msgid ""
"Removes background noise from your voice with the GTCRN neural network. "
"Higher intensity = stronger cleanup."
msgstr ""
"GTCRN sinir ağı ile sesinizden arka plan gürültüsünü kaldırır. Yüksek "
"yoğunluk = daha güçlü temizlik."

#: src/ui/views/simple.rs:170
msgid "System sound"
msgstr "Sistem sesi"

#: src/ui/views/simple.rs:171
msgid ""
"Cleans background noise from everything you hear before it reaches your "
"speakers."
msgstr ""
"Hoparlörlerinize ulaşmadan önce duyduğunuz her şeyin arka plan gürültüsünü "
"temizler."

