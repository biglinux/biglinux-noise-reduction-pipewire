#: src/ui/window.rs:369
msgid ""
"AI-powered microphone noise reduction with GTK4/libadwaita interface for "
"PipeWire."
msgstr ""
"PipeWire için GTK4/libadwaita arayüzlü yapay zeka destekli mikrofon gürültü "
"azaltma."

#: src/ui/views/mic.rs:44
msgid "Noise filter — fine-tune"
msgstr "Gürültü filtresi — ince ayar"

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 581
#: src/ui/views/mic.rs:50
