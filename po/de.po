# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 308
#: src/ui/views/mic.rs:251 src/ui/views/output.rs:180
msgid "Silence gate"
msgstr "Stummschalt-Tor"

#: src/ui/views/mic.rs:253
msgid ""
"Mutes the mic during pauses so listeners hear silence instead of hiss. "
"Higher = more aggressive."
msgstr ""
"Stummschaltet das Mikrofon während Pausen, sodass Zuhörer Stille statt "
"Rauschen hören. Höher = aggressiver."

