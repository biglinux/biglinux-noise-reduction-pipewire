# pipewire/src/biglinux_microphone/ui/main_view.py, line: 477
#: src/ui/views/mic.rs:232 src/ui/views/output.rs:161
msgid "High-pass filter"
msgstr "Υψηλοπερατό φίλτρο"

#: src/ui/views/mic.rs:233
msgid "Cuts low-frequency rumble — AC, wind, mic-stand bumps."
msgstr ""
"Αφαιρεί το βούισμα χαμηλών συχνοτήτων — ρεύμα, άνεμος, χτυπήματα στο "
"μικρόφωνο."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 308
#: src/ui/views/mic.rs:251 src/ui/views/output.rs:180
msgid "Silence gate"
msgstr "Πύλη σιωπής"

#: src/ui/views/mic.rs:253
msgid ""
"Mutes the mic during pauses so listeners hear silence instead of hiss. "
"Higher = more aggressive."
msgstr ""
"Αθόρυβο μικρόφωνο κατά τις παύσεις ώστε οι ακροατές να ακούνε σιωπή αντί για"
" θόρυβο. Μεγαλύτερη τιμή = πιο επιθετικό."

# File: biglinux-noise-reduction-
# pipewire/src/biglinux_microphone/ui/main_view.py, line: 477
#: src/ui/views/mic.rs:273 src/ui/views/output.rs:57
