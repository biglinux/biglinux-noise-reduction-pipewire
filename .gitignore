# Rust
/target/
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/
**/*.rs.bk
Cargo.lock.orig

# makepkg work dirs
/packaging/arch/pkg/
/packaging/arch/src/
/packaging/arch/*.pkg.tar.*
/packaging/arch/*.log

# Compiled translations (built during makepkg from po/*.po)
build-locale/
*.mo

# IDE / editor
.vscode/
.idea/
*.swp
*~

# OS / shell scratch
.DS_Store
Thumbs.db
.envrc.local

# Coverage / instrumentation
*.profraw
tarpaulin-report.html
cobertura.xml

# Calibration system: virtualenv + ad-hoc artefacts. Models and
# datasets fetched by setup.sh live in $XDG_CACHE_HOME, never inside
# the repo, but cover stray local copies just in case.
scripts/calibrate/.venv/
scripts/calibrate/**/__pycache__/
scripts/calibrate/reports/
scripts/calibrate/signals/
scripts/calibrate/models/
scripts/calibrate/datasets/
